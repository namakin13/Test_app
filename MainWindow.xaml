<Window x:Class="SteamLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SteamLauncher"
        mc:Ignorable="d"
        Title="Steam Game Launcher" Height="600" Width="450"
        Background="#121212" Foreground="White">
    
    <Window.Resources>
        <!-- カードスタイルの背景設定 -->
        <Style x:Key="GameCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E1E26"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.3" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- モダンなボタンのスタイル -->
        <Style x:Key="LaunchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00D4FF"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00A3C2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="STEAM LIBRARY" FontSize="12" FontWeight="Bold" Foreground="#00D4FF" LetterSpacing="2"/>
            <TextBlock Text="My Games" FontSize="28" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- ゲーム一覧 (カード形式) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GamesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GameCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ゲームバナー画像 (非同期読み込み) -->
                                <Image Grid.Row="0" Grid.ColumnSpan="2"
                                       Height="150"
                                       Stretch="UniformToFill"
                                       Margin="0,0,0,10"
                                       Source="{Binding HeaderImageUrl, IsAsync=True}"
                                       ImageFailed="OnImageFailed">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,400,150" RadiusX="4" RadiusY="4"/>
                                    </Image.Clip>
                                </Image>

                                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Medium" Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding AppId}" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Button Grid.Row="1" Grid.Column="1" 
                                        Content="起動" 
                                        Style="{StaticResource LaunchButtonStyle}"
                                        Click="OnLaunchButtonClick"
                                        Tag="{Binding AppId}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
